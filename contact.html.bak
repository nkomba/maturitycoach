<!-- HERO -->
<section class="contact-hero">
  <div class="contact-hero-inner">
    <div>
      <div class="section-label" style="color:var(--gold); margin-bottom:20px;">Start Here</div>
      <h1 class="display-2">Begin with a conversation</h1>
      <p>No pitch. No pressure. Just 30 minutes of honest dialogue to explore what's possible — for you, your leadership, and the life you want to build.</p>
    </div>
    <div class="contact-hero-right">
      <div class="hero-detail-card">
        <div class="detail-icon">🕐</div>
        <div>
          <div class="detail-title">30 Minutes</div>
          <div class="detail-text">Exploratory conversation, completely free of charge</div>
        </div>
      </div>
      <div class="hero-detail-card">
        <div class="detail-icon">🌍</div>
        <div>
          <div class="detail-title">Video or Phone</div>
          <div class="detail-text">Meet from anywhere — clients across 6 continents</div>
        </div>
      </div>
      <div class="hero-detail-card">
        <div class="detail-icon">🔒</div>
        <div>
          <div class="detail-title">Fully Confidential</div>
          <div class="detail-text">Everything discussed remains entirely private</div>
        </div>
      </div>
      <div class="hero-detail-card">
        <div class="detail-icon">✨</div>
        <div>
          <div class="detail-title">No Obligation</div>
          <div class="detail-text">A genuine conversation — not a sales call</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT MAIN -->
<section class="contact-main">
  <div class="container">
    <div class="contact-grid">

      <!-- FORM -->
      <div class="contact-form-card fade-up">
        <div id="formContent">
          <div class="form-title">Tell Eugene about yourself</div>
          <p class="form-subtitle">Share a little about where you are and what you're looking for.</p>

          <form id="contactForm" class="contact-form" onsubmit="handleSubmit(event)">
            <div class="form-row">
              <div class="form-group">
                <label for="firstName">First Name</label>
                <input type="text" id="firstName" placeholder="Your first name" required />
              </div>
              <div class="form-group">
                <label for="lastName">Last Name</label>
                <input type="text" id="lastName" placeholder="Your last name" required />
              </div>
            </div>

            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" placeholder="your@email.com" required />
            </div>

            <div class="form-group">
              <label for="role">Your Role</label>
              <input type="text" id="role" placeholder="e.g. CEO, Founder, Managing Director" />
            </div>

            <div class="form-group">
              <label for="interest">What brings you here?</label>
              <select id="interest">
                <option value="" disabled selected>Select the best description...</option>
                <option>I want 1:1 executive coaching</option>
                <option>I'm interested in the Maturity Circle cohort</option>
                <option>I want leadership coaching for my team/organization</option>
                <option>I want to book Eugene to speak</option>
                <option>I'm just exploring — not sure yet</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">What's most alive for you right now?</label>
              <textarea id="message" placeholder="Share what's on your mind — what's working, what isn't, and what you most want to change or create..."></textarea>
            </div>

            <button type="submit" class="form-submit-btn">
              Send My Message
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </button>
          </form>
        </div>

        <div class="form-success" id="formSuccess">
          <div class="success-icon">✉️</div>
          <h3>Thank you for reaching out</h3>
          <p>Eugene personally reads every message and will be in touch within one business day. In the meantime, you're welcome to explore the <a href="philosophy.html" style="color:var(--gold);">philosophy</a> behind the work.</p>
        </div>
      </div>

      <!-- SIDEBAR -->
      <div class="contact-sidebar">
        <div class="sidebar-card fade-up">
          <div class="sidebar-title">Direct contact</div>
          <div class="contact-detail">
            <div class="contact-detail-icon">✉️</div>
            <div>
