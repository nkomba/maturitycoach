#!/bin/sh
#
# Pre-commit hook for maturity.coach
#
# Install:
#   cp tools/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Blocks a commit if the site has placeholders, broken links, case
# mismatches that break on GitHub Pages, retired single-coach wording,
# or coach lists that have drifted from data/coaches.json.
#
# Bypass once (use sparingly):  git commit --no-verify

if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: node not found — skipping site checks."
  exit 0
fi

node tools/check-site.mjs || {
  echo ""
  echo "Commit blocked. Fix the errors above, or re-run with --no-verify."
  exit 1
}
