<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Eugene Nkomba — Maturity Coach</title>
  <meta name="description" content="Eugene Nkomba is an executive coach and managing partner at Maturity Coach — specializing in the AI-era intersection of ancient wisdom, neuroscience, and modern leadership." />
  <link rel="stylesheet" href="style.css" />
  <style>
    /* ── ABOUT PAGE ── */

    /* Hero */
    .about-hero {
      min-height: 70vh;
      background: var(--charcoal);
      display: flex;
      align-items: flex-end;
      position: relative;
      overflow: hidden;
      padding-top: var(--nav-height);
    }

    .about-hero-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 80% at 80% 40%, rgba(184,151,90,0.1) 0%, transparent 60%);
    }

    .about-hero-inner {
      position: relative;
      z-index: 2;
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 80px 32px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      width: 100%;
    }

    .about-hero h1 { color: var(--white); margin-bottom: 16px; }
    .about-hero-title { color: var(--gold); font-size: 14px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 28px; }

    .about-hero p { color: rgba(255,255,255,0.65); max-width: 460px; font-size: 19px; line-height: 1.65; font-weight: 300; }

    .portrait-block {
      display: flex;
      justify-content: flex-end;
    }

    .portrait-frame {
      width: 320px;
      height: 400px;
      background: linear-gradient(160deg, rgba(184,151,90,0.2) 0%, rgba(184,151,90,0.05) 100%);
      border-radius: 24px;
      border: 1px solid rgba(184,151,90,0.25);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .portrait-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
      border-radius: 24px;
    }

    .portrait-initials {
      display: none;
      font-family: var(--font-serif);
      font-size: 100px;
      color: rgba(184,151,90,0.2);
      letter-spacing: -0.04em;
    }

    .portrait-accent {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 80px;
      background: linear-gradient(to top, rgba(184,151,90,0.12), transparent);
    }

    .portrait-deco {
      position: absolute;
      top: -40px;
      right: -40px;
      width: 160px;
      height: 160px;
      border: 1px solid rgba(184,151,90,0.15);
      border-radius: 50%;
    }

    /* Bio Sections */
    .bio-section {
      padding: 100px 0;
    }

    .bio-lead {
      font-family: var(--font-serif);
      font-size: clamp(22px, 3vw, 32px);
      line-height: 1.5;
      color: var(--text-primary);
      margin-bottom: 40px;
      padding-bottom: 40px;
      border-bottom: 1px solid var(--border);
    }

    .bio-body {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 80px;
      align-items: start;
    }

    .bio-body p {
      font-size: 17px;
      line-height: 1.75;
      color: var(--text-secondary);
      margin-bottom: 24px;
    }

    .bio-body p:last-child { margin-bottom: 0; }

    .credentials-panel {
      background: var(--cream);
      border-radius: var(--radius-lg);
      padding: 36px;
      position: sticky;
      top: calc(var(--nav-height) + 24px);
    }

    .credential-item {
      padding: 20px 0;
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }

    .credential-item:last-child { border-bottom: none; padding-bottom: 0; }
    .credential-item:first-child { padding-top: 0; }

    .credential-label { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
    .credential-value { font-size: 15px; color: var(--text-primary); line-height: 1.5; }

    /* Philosophy of Self */
    .values-section {
      background: var(--charcoal);
      padding: 100px 0;
    }

    .values-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
      margin-top: 56px;
    }

    .value-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: var(--radius-lg);
      padding: 36px;
      transition: var(--transition);
    }

    .value-card:hover {
      background: rgba(184,151,90,0.06);
      border-color: rgba(184,151,90,0.2);
    }

    .value-number {
      font-family: var(--font-serif);
      font-size: 42px;
      color: rgba(184,151,90,0.2);
      line-height: 1;
      margin-bottom: 16px;
    }

    .value-title { font-family: var(--font-serif); font-size: 22px; color: var(--white); margin-bottom: 12px; }
    .value-text { font-size: 15px; color: rgba(255,255,255,0.55); line-height: 1.7; }

    /* Approach Timeline */
    .approach-section {
      padding: 100px 0;
      background: var(--cream);
    }

    .timeline {
      margin-top: 60px;
      position: relative;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 28px;
      top: 0; bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, var(--gold), transparent);
    }

    .timeline-item {
      display: flex;
      gap: 40px;
      margin-bottom: 48px;
      align-items: flex-start;
    }

    .timeline-item:last-child { margin-bottom: 0; }

    .timeline-dot {
      width: 56px;
      height: 56px;
      flex-shrink: 0;
      background: var(--white);
      border: 2px solid var(--gold);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      position: relative;
      z-index: 1;
    }

    .timeline-content {
      padding-top: 12px;
    }

    .timeline-title { font-family: var(--font-serif); font-size: 22px; color: var(--text-primary); margin-bottom: 10px; }
    .timeline-text { font-size: 16px; color: var(--text-secondary); line-height: 1.7; }

    /* CTA */
    .about-cta {
      padding: 100px 0;
      text-align: center;
      background: var(--white);
    }

    @media (max-width: 768px) {
      .about-hero-inner { grid-template-columns: 1fr; gap: 40px; padding: 48px 20px 60px; }
      .portrait-block { display: none; }
      .bio-body { grid-template-columns: 1fr; gap: 40px; }
      .credentials-panel { position: static; }
      .values-grid { grid-template-columns: 1fr; }
    }
    /* Override for pages with dark heroes */
@media (max-width: 768px) {
  .nav {
    background: rgba(28,28,30,0.98) !important;
  }
  .nav.scrolled {
    background: rgba(28,28,30,0.98) !important;
  }
  .nav-logo, .nav-logo .logo-text, .nav-links a, .nav-hamburger span {
    color: var(--white) !important;
  }
}

/* Desktop: keep white nav always */
@media (min-width: 769px) {
  .nav {
    background: var(--white) !important;
  }
  .nav-logo, .nav-logo .logo-text {
    color: var(--charcoal) !important;
  }
}
  </style>
</head>
<body>

<!-- ═══════════════ NAVIGATION ═══════════════ -->
<nav class="nav scrolled" id="mainNav">
  <div class="nav-inner">
    <a href="index.html" class="nav-logo">
      <div class="logo-mark">M</div>
      <span class="logo-text">Maturity<span>Coach</span></span>
    </a>
    <div class="nav-links">
      <a href="philosophy.html">Philosophy</a>
      <a href="services.html">Services</a>
      <a href="perspectives.html">Perspectives</a>
      <a href="about.html">About Eugene</a>
      <a href="/app/">Get the App</a>
      <a href="contact.html" class="nav-cta">Request Confidential Consultation</a>
    </div>
    <div class="nav-hamburger" onclick="toggleMenu()">
      <span></span><span></span><span></span>
    </div>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="philosophy.html" onclick="toggleMenu()">Philosophy</a>
  <a href="services.html" onclick="toggleMenu()">Services</a>
  <a href="perspectives.html" onclick="toggleMenu()">Perspectives</a>
  <a href="about.html" onclick="toggleMenu()">About Eugene</a>
