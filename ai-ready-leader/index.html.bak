  <!-- JAVASCRIPT -->
  <script>
    (function() {
      'use strict';

      // Form handler
      var aiForm = document.getElementById('aiForm');
      var formContainer = document.getElementById('formContainer');
      var successContainer = document.getElementById('successContainer');

      if (aiForm) {
        aiForm.addEventListener('submit', function(e) {
          e.preventDefault();
          var formData = new FormData(aiForm);
          var data = {};
          formData.forEach(function(value, key) { data[key] = value; });

          var submitBtn = aiForm.querySelector('button[type="submit"]');
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending...';
          }

          // PRODUCTION: Replace with actual endpoint
          /*
          fetch('YOUR_ENDPOINT', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(data)
          }).then(function(res) {
            if (res.ok) { showSuccess(); } else { showError(submitBtn); }
          }).catch(function(err) { showError(submitBtn); });
          */

          // DEMO MODE
          console.log('AI Framework download:', data);
          setTimeout(function() { showSuccess(); }, 800);
        });
      }

      function showSuccess() {
        if (formContainer) formContainer.style.display = 'none';
        if (successContainer) successContainer.classList.add('show');
        if (successContainer) successContainer.scrollIntoView({ behavior: 'smooth', block: 'center' });
        if (typeof gtag === 'function') {
          gtag('event', 'ai_framework_downloaded', {
            'event_category': 'engagement',
            'event_label': 'AI-Ready Leader Framework',
            'value': 1
          });
        }
      }

      function showError(submitBtn) {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Try Again'; }
        alert('Something went wrong. Please try again or email hello@maturity.coach');
      }

      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
        anchor.addEventListener('click', function(e) {
          var targetId = this.getAttribute('href');
          if (targetId === '#' || targetId === '') return;
          var target = document.querySelector(targetId);
          if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
        });
      });

      console.log('AI-Ready Leader landing page loaded.');
    })();
  </script>
