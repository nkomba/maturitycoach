            Take the Self-Assessment
          </a>
        </div>
      </div>
      
      <!-- Terminal credential card -->
      <div style="background:rgba(10,10,25,0.85); border:1px solid rgba(184,151,90,0.3); border-radius:12px; overflow:hidden; backdrop-filter:blur(8px);">
        <div style="display:flex; align-items:center; gap:8px; padding:12px 16px; background:rgba(255,255,255,0.05); border-bottom:1px solid rgba(184,151,90,0.2);">
          <div style="width:12px; height:12px; border-radius:50%; background:#ff5f57;"></div>
          <div style="width:12px; height:12px; border-radius:50%; background:#ffbd2e;"></div>
          <div style="width:12px; height:12px; border-radius:50%; background:#28ca42;"></div>
