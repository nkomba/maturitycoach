<!-- HERO -->
<section class="lp-hero">
  <div class="container">
    <div class="lp-hero-inner">
      <div>
        <div class="lp-badge">
          <span>✦</span> For Technical Leaders
        </div>
        <h1>
          You Mastered the <span class="strike">Technology</span>.<br>
          Now Master the <span class="highlight">Leadership</span>.
        </h1>
        <p class="lp-hero-sub">
          Every CISO, CTO, and technical director faces the same wall: the skills
          that got you here are not the ones that get you further.
          I speak both languages fluently. Let's talk.
        </p>
        <div style="display:flex; gap:16px; flex-wrap:wrap;">
          <a href="contact.html" class="btn btn-gold">
            Book Your 30-Minute Exploratory Call
          </a>
