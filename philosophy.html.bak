<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Philosophy — Maturity Coach</title>
  <meta name="description" content="The Maturity Coach philosophy: ancient wisdom traditions, modern neuroscience, and AI-era technology — united in service of leaders who want to live fully and lead wisely." />
  <link rel="stylesheet" href="style.css" />
  <style>
    /* ── PHILOSOPHY PAGE ── */

    .philosophy-hero {
      background: var(--charcoal);
      padding: calc(var(--nav-height) + 80px) 0 100px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .philosophy-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 50% 70% at 30% 60%, rgba(184,151,90,0.07) 0%, transparent 60%),
        radial-gradient(ellipse 50% 70% at 70% 30%, rgba(184,151,90,0.05) 0%, transparent 60%);
    }

    .philosophy-hero h1 { color: var(--white); position: relative; z-index: 1; margin-bottom: 24px; }
    .philosophy-hero p { color: rgba(255,255,255,0.6); max-width: 620px; margin: 0 auto; position: relative; z-index: 1; }

    /* The Core Tension */
    .tension-section {
      padding: 100px 0;
      background: var(--white);
    }

    .tension-blocks {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 0;
      align-items: center;
      margin-top: 64px;
    }

    .tension-block {
      padding: 48px;
      border-radius: var(--radius-xl);
    }

    .tension-block-ancient {
      background: var(--cream);
      text-align: right;
    }

    .tension-block-modern {
      background: var(--charcoal);
    }

    .tension-center {
      width: 80px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      position: relative;
      z-index: 1;
    }

    .tension-center-symbol {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, var(--gold-dark), var(--gold));
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      box-shadow: 0 0 0 8px white;
    }

    .tension-line {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, var(--gold), transparent);
    }

    .tension-block-title {
      font-family: var(--font-serif);
      font-size: clamp(20px, 3vw, 28px);
      margin-bottom: 16px;
    }

    .tension-block-ancient .tension-block-title { color: var(--text-primary); }
    .tension-block-modern .tension-block-title { color: var(--white); }

    .tension-block-text { font-size: 16px; line-height: 1.7; }
    .tension-block-ancient .tension-block-text { color: var(--text-secondary); }
    .tension-block-modern .tension-block-text { color: rgba(255,255,255,0.55); }

    .tension-items { margin-top: 24px; }
    .tension-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      font-size: 15px;
    }
    .tension-block-ancient .tension-item { justify-content: flex-end; color: var(--text-secondary); }
    .tension-block-modern .tension-item { color: rgba(255,255,255,0.65); }
    .tension-item-dot { width: 6px; height: 6px; background: var(--gold); border-radius: 50%; flex-shrink: 0; }

    /* The Three Pillars Deep Dive */
    .pillars-deep {
      background: var(--cream);
      padding: 100px 0;
    }

    .pillar-deep {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 60px;
      align-items: start;
      padding: 60px 0;
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }

    .pillar-deep:last-child { border-bottom: none; }

    .pillar-deep-number {
      font-family: var(--font-serif);
      font-size: 80px;
      color: rgba(184,151,90,0.15);
      line-height: 1;
    }

    .pillar-deep-label { font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
    .pillar-deep-title { font-family: var(--font-serif); font-size: clamp(24px, 3.5vw, 36px); color: var(--text-primary); margin-bottom: 20px; }
    .pillar-deep-text { font-size: 17px; color: var(--text-secondary); line-height: 1.75; margin-bottom: 16px; }
    .pillar-deep-text:last-child { margin-bottom: 0; }

    .wisdom-quote {
      margin-top: 24px;
      padding: 24px 0 24px 24px;
      border-left: 2px solid var(--gold);
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 17px;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .wisdom-quote cite {
      display: block;
      margin-top: 8px;
      font-size: 12px;
      font-style: normal;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--gold);
    }

    /* The Maturity Model */
    .model-section {
      padding: 100px 0;
      background: var(--white);
    }

    .maturity-model {
      background: var(--charcoal);
      border-radius: var(--radius-xl);
      padding: 60px;
      margin-top: 60px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2px;
      overflow: hidden;
    }

    .model-step {
      background: rgba(255,255,255,0.03);
      padding: 36px 28px;
      text-align: center;
      transition: var(--transition);
      position: relative;
    }

    .model-step:hover { background: rgba(184,151,90,0.08); }

    .model-step::after {
      content: '→';
      position: absolute;
      right: -12px;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(184,151,90,0.3);
      font-size: 20px;
      z-index: 1;
    }

    .model-step:last-child::after { display: none; }

    .model-step-num { font-family: var(--font-serif); font-size: 40px; color: rgba(184,151,90,0.25); line-height: 1; margin-bottom: 16px; }
    .model-step-title { font-family: var(--font-serif); font-size: 18px; color: var(--white); margin-bottom: 12px; }
    .model-step-text { font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.65; }

    /* Humanity section */
    .humanity-section {
      background: linear-gradient(135deg, var(--gold-dark), var(--gold));
      padding: 100px 0;
      position: relative;
      overflow: hidden;
    }

    .humanity-section::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }

    .humanity-inner { position: relative; z-index: 1; text-align: center; }
    .humanity-inner h2 { color: var(--white); margin-bottom: 24px; }
    .humanity-inner p { color: rgba(255,255,255,0.85); font-size: 19px; line-height: 1.7; max-width: 680px; margin: 0 auto 48px; }

    @media (max-width: 768px) {
      .tension-blocks { grid-template-columns: 1fr; }
      .tension-center { flex-direction: row; width: 100%; justify-content: center; }
      .tension-line { width: 40px; height: 1px; background: linear-gradient(to right, var(--gold), transparent); }
      .tension-block-ancient { text-align: left; }
      .tension-block-ancient .tension-item { justify-content: flex-start; }
      .pillar-deep { grid-template-columns: 1fr; gap: 24px; }
      .maturity-model { grid-template-columns: 1fr 1fr; padding: 32px 24px; }
      .model-step::after { display: none; }
    }
    /* Override for pages with dark heroes */
    @media (max-width: 768px) {
      .nav {
        background: rgba(28,28,30,0.98) !important;
      }
      .nav.scrolled {
        background: rgba(28,28,30,0.98) !important;
      }
      .nav-logo, .nav-logo .logo-text, .nav-links a, .nav-hamburger span {
        color: var(--white) !important;
      }
    }

    /* Desktop: keep white nav always */
    @media (min-width: 769px) {
      .nav {
        background: var(--white) !important;
      }
      .nav-logo, .nav-logo .logo-text {
        color: var(--charcoal) !important;
      }
    }
  </style>
<style id="unified-nav-styles">
  /* Full-width submenu bar: opens ACROSS THE TOP, under the nav */
  .nav-links .nav-group { position: static; align-self: stretch; display: flex; align-items: center; }
  .nav-links .nav-group > .nav-group-trigger { display: inline-flex; align-items: center; gap: 6px; height: 100%; position: relative; }
  .nav-links .nav-group > .nav-group-trigger::after { display: none; }
  .nav-caret { width: 9px; height: 9px; opacity: .65; transition: transform .3s cubic-bezier(.4,0,.2,1); }
  .nav-group:hover .nav-caret { transform: rotate(180deg); }
  .nav-dropdown {
    position: absolute; top: 100%; left: 0; right: 0; box-sizing: border-box;
    display: flex; flex-wrap: wrap; justify-content: center; align-items: stretch; gap: 6px;
    padding: 16px 32px;
    background: var(--white, #fff);
    border-top: 1px solid var(--border, rgba(0,0,0,.08));
    border-bottom: 1px solid var(--border, rgba(0,0,0,.08));
    box-shadow: 0 24px 50px rgba(28,28,30,.10);
    opacity: 0; visibility: hidden; pointer-events: none; transform: translateY(-8px);
    transition: opacity .24s ease, transform .24s cubic-bezier(.4,0,.2,1), visibility .24s; z-index: 9998;
  }
  .nav-dropdown::before { content: ''; position: absolute; left: 0; right: 0; top: -26px; height: 26px; }
  .nav-group:hover .nav-dropdown, .nav-group:focus-within .nav-dropdown {
    opacity: 1; visibility: visible; pointer-events: auto; transform: translateY(0);
  }
  .nav-dropdown a {
    display: block; padding: 12px 18px; border-radius: var(--radius-sm, 8px);
    font-size: 14px; line-height: 1.35; color: var(--text-primary, #1a1a1a);
    min-width: 180px; white-space: nowrap;
  }
  .nav-dropdown a::after { display: none; }
  .nav-dropdown a:hover { background: var(--cream, #f7f3ec); color: var(--gold-dark, #8b6e3a); }
  .nav-dropdown .dropdown-desc {
    display: block; margin-top: 3px; font-size: 12px; font-weight: 400;
    color: var(--text-secondary, #6b6b76); white-space: nowrap;
  }
  .nav-dropdown .tag {
    display: inline-block; margin-left: 8px; font-size: 10px; letter-spacing: .06em;
    text-transform: uppercase; color: var(--gold-dark, #8b6e3a);
    background: rgba(184,151,90,.14); padding: 2px 8px; border-radius: 100px; vertical-align: middle;
  }
  /* Featured "quick value" group */
  .nav-links .nav-group.featured > .nav-group-trigger { color: var(--gold-dark, #8b6e3a); font-weight: 600; }
  .nav-links .nav-group.featured > .nav-group-trigger .nav-caret { opacity: .9; }
  /* Active page state (set automatically by the injected script) */
  .nav-links > a.active { color: var(--text-primary, #1a1a1a); }
  .nav-links > a.active::after { transform: scaleX(1); }
  .nav-links > a.nav-cta.active { background: var(--gold, #b8975a); }
  .nav-links .nav-group.active > .nav-group-trigger { color: var(--gold-dark, #8b6e3a); font-weight: 600; }
  .nav-links .nav-group.active > .nav-group-trigger::before {
    content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 3px;
    background: var(--gold, #b8975a); border-radius: 3px 3px 0 0;
  }
  .nav-dropdown a.active { background: var(--cream, #f7f3ec); color: var(--gold-dark, #8b6e3a); font-weight: 600; }
  .mobile-menu a.active { color: var(--gold-dark, #8b6e3a); font-weight: 600; }
  /* Mobile grouped menu */
  .mobile-menu .m-label {
    display: block; padding: 20px 32px 2px; text-align: center;
    font-size: 11px; letter-spacing: .16em; text-transform: uppercase;
    color: var(--gold, #b8975a); border: none;
    font-family: var(--font-sans, system-ui, -apple-system, sans-serif);
  }
  .mobile-menu .m-label:first-child { padding-top: 10px; }
  .mobile-menu a.m-assess { color: var(--gold-dark, #8b6e3a); }
  .mobile-menu a.m-cta { color: var(--white, #fff); background: var(--charcoal, #1c1c1e); }
  @media (max-width: 1040px) { .nav-links { gap: 20px; } }
</style>
<script id="unified-nav-script">
document.addEventListener('DOMContentLoaded', function () {
  function seg(url) {
    try {
      var a = document.createElement('a'); a.href = url;
      var s = a.pathname.split('/').filter(Boolean).pop();
      return (s || 'index.html').toLowerCase();
    } catch (e) { return ''; }
  }
  var here = seg(window.location.href) || 'index.html';
  var links = document.querySelectorAll('#mainNav .nav-links a, #mobileMenu a');
  Array.prototype.forEach.call(links, function (link) {
    var href = link.getAttribute('href');
    if (!href || href.charAt(0) === '#' || href.indexOf('mailto:') === 0) return;
    if (seg(href) === here) {
      link.classList.add('active');
      var g = link.closest && link.closest('.nav-group');
      if (g) g.classList.add('active');
    }
  });
});
</script>
</head>
