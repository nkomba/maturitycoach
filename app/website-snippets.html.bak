<!-- =====================================================================
     "Get the App" snippets for maturity.coach
     Brand-matched and self-contained (inline styles), so they render
     regardless of your existing CSS. All link to /app/ (where you'll
     publish the app). Copy the piece you want into your site's HTML.
     ===================================================================== -->


<!-- ------------------------------------------------------------------
     1) NAV LINK  —  add alongside your other nav items
     (your nav appears twice in the page: a desktop list and a mobile
      list — add this to BOTH so it shows in each.)
------------------------------------------------------------------- -->
<a href="/app/"
   style="color:#c2a15f;font-weight:600;text-decoration:none;">Get the App</a>


<!-- ------------------------------------------------------------------
     2) HERO BUTTON  —  a gold pill that matches your call-to-action
     buttons. Place next to "Begin the Journey".
------------------------------------------------------------------- -->
<a href="/app/"
   style="display:inline-flex;align-items:center;gap:8px;
          background:#a8863f;color:#fff;font-family:inherit;font-weight:600;
          font-size:15px;padding:14px 26px;border-radius:999px;
          text-decoration:none;box-shadow:0 6px 20px rgba(34,38,31,.18);">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
       stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11 18h2"/>
  </svg>
  Get the App
</a>


<!-- ------------------------------------------------------------------
     3) FULL-WIDTH BANNER  —  drop this section in near the footer
     (e.g., just before "Ready to lead from your full self?").
------------------------------------------------------------------- -->
<section style="background:linear-gradient(155deg,#2b322a,#20241f 70%);
                color:#f2eede;padding:56px 24px;text-align:center;">
  <div style="max-width:620px;margin:0 auto;">
    <div style="font-size:12px;letter-spacing:.18em;text-transform:uppercase;
                color:#c2a15f;font-weight:600;margin-bottom:14px;">
      Now on your phone
    </div>
    <h2 style="font-family:'Iowan Old Style',Palatino,Georgia,serif;
               font-weight:600;font-size:30px;line-height:1.2;margin:0 0 14px;">
      Carry the practice with you
    </h2>
    <p style="font-size:16px;line-height:1.6;color:#d8d2bf;margin:0 auto 26px;max-width:480px;">
      Daily wisdom, a maturity self-assessment, private journaling, and your
      path to coaching &mdash; installable on iPhone and Android. No app store needed.
    </p>
    <a href="/app/"
       style="display:inline-flex;align-items:center;gap:8px;background:#c2a15f;
              color:#20241f;font-weight:700;font-size:15px;padding:15px 30px;
              border-radius:999px;text-decoration:none;">
      Open the App
    </a>
    <div style="font-size:13px;color:#a7a189;margin-top:16px;">
      On iPhone: tap Share &rarr; Add to Home Screen &nbsp;·&nbsp; On Android: tap Install
    </div>
  </div>
</section>


<!-- ------------------------------------------------------------------
     Tip: if you'd rather these use your own CSS classes instead of
     inline styles, share your homepage HTML and I'll match them exactly.
------------------------------------------------------------------- -->
