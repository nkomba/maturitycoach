<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="theme-color" content="#22261f" />
<title>Maturity Coach</title>
<link rel="manifest" href="manifest.webmanifest" />
<link rel="apple-touch-icon" href="icon.svg" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Maturity" />
<style>
  :root{
    --ink:#22261f; --ink-soft:#3a4034; --ink-2:#2c322a;
    --paper:#f6f2e9; --paper-2:#efe8d9; --card:#fffdf8;
    --sage:#7d8c6a; --sage-deep:#5f6e4e;
    --gold:#c2a15f; --gold-deep:#a8863f;
    --line:rgba(34,38,31,.12); --muted:#6d7266;
    --serif:'Iowan Old Style','Palatino Linotype','Palatino','Georgia',serif;
    --sans:system-ui,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
    --shadow:0 6px 24px rgba(34,38,31,.10);
    --nav-h:64px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{
    font-family:var(--sans); color:var(--ink); background:var(--paper);
    -webkit-font-smoothing:antialiased; line-height:1.5;
    overscroll-behavior-y:contain;
  }
  #app{max-width:520px;margin:0 auto;min-height:100%;background:var(--paper);
    position:relative;padding-bottom:calc(var(--nav-h) + env(safe-area-inset-bottom));}
  /* Header */
  header{position:sticky;top:0;z-index:20;background:rgba(246,242,233,.92);
    backdrop-filter:blur(10px);border-bottom:1px solid var(--line);
    padding:calc(env(safe-area-inset-top) + 12px) 20px 12px;display:flex;align-items:center;gap:10px}
  .mono{width:34px;height:34px;border-radius:9px;background:var(--ink);color:var(--paper);
    display:grid;place-items:center;font-family:var(--serif);font-weight:600;font-size:19px;
    box-shadow:var(--shadow)}
  .brand b{font-family:var(--serif);font-weight:600;font-size:17px;letter-spacing:.2px;display:block;line-height:1.1}
  .brand span{font-size:11px;color:var(--muted);letter-spacing:.14em;text-transform:uppercase}
  /* Views */
  main{padding:18px 18px 28px;animation:fade .35s ease}
  @keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .view{display:none}
  .view.active{display:block}
  h2.title{font-family:var(--serif);font-weight:600;font-size:26px;line-height:1.15;margin:2px 0 4px}
  .sub{color:var(--muted);font-size:14px;margin-bottom:16px}
  .eyebrow{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--sage-deep);font-weight:600;margin-bottom:8px}
  /* Cards */
  .card{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:18px;box-shadow:var(--shadow);margin-bottom:14px}
  .hero{background:linear-gradient(155deg,#2b322a,#20241f 70%);color:#f2eede;border:none;position:relative;overflow:hidden}
  .hero:before{content:"";position:absolute;inset:0;background:radial-gradient(120% 80% at 100% 0,rgba(194,161,95,.22),transparent 60%)}
  .hero *{position:relative}
  .hero .eyebrow{color:var(--gold)}
  .quote{font-family:var(--serif);font-size:22px;line-height:1.35;margin:6px 0 12px;font-weight:500}
  .attr{font-size:13px;color:#c9c3ac;letter-spacing:.02em}
  .attr b{color:var(--gold);font-weight:600}
  .prompt{margin-top:16px;padding-top:16px;border-top:1px solid rgba(255,255,255,.14);font-size:14.5px;color:#e7e2cf}
  .prompt em{color:#fff;font-style:normal;font-weight:600;display:block;margin-bottom:8px;font-size:12px;letter-spacing:.12em;text-transform:uppercase}
  /* Buttons */
  .btn{appearance:none;border:none;cursor:pointer;font-family:var(--sans);font-size:15px;font-weight:600;
    padding:13px 18px;border-radius:12px;background:var(--ink);color:var(--paper);width:100%;
    transition:transform .08s ease,opacity .2s;display:inline-flex;align-items:center;justify-content:center;gap:8px;text-decoration:none}
  .btn:active{transform:scale(.98)}
  .btn.gold{background:var(--gold-deep)}
  .btn.sage{background:var(--sage-deep)}
  .btn.ghost{background:transparent;color:var(--ink);border:1.5px solid var(--line)}
  .btn.sm{width:auto;padding:9px 14px;font-size:13.5px;border-radius:10px}
  .row{display:flex;gap:10px}
  .row .btn{width:auto;flex:1}
  /* Stats */
  .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
  .stat{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:14px 10px;text-align:center}
  .stat b{font-family:var(--serif);font-size:24px;display:block;line-height:1}
  .stat span{font-size:11px;color:var(--muted);letter-spacing:.04em;text-transform:uppercase}
  /* Quick links */
  .quick{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .tile{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px;cursor:pointer;transition:transform .08s;display:flex;flex-direction:column;gap:8px}
  .tile:active{transform:scale(.98)}
  .tile .ic{width:30px;height:30px;color:var(--sage-deep)}
  .tile b{font-family:var(--serif);font-size:16px;font-weight:600}
  .tile span{font-size:12.5px;color:var(--muted);line-height:1.4}
  /* Assessment */
  .q{margin-bottom:20px}
  .q p{font-size:16px;font-weight:500;margin-bottom:12px}
  .q .dimtag{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--sage-deep);font-weight:600;margin-bottom:6px}
  .scale{display:flex;gap:6px}
  .scale button{flex:1;padding:11px 0;border:1.5px solid var(--line);background:var(--card);border-radius:10px;font-weight:700;font-size:15px;color:var(--ink-soft);cursor:pointer;transition:.12s}
  .scale button.on{background:var(--sage-deep);color:#fff;border-color:var(--sage-deep);transform:translateY(-1px)}
  .scale-legend{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-top:6px}
  .progressbar{height:6px;background:var(--paper-2);border-radius:99px;overflow:hidden;margin:4px 0 18px}
  .progressbar i{display:block;height:100%;background:linear-gradient(90deg,var(--sage),var(--gold));width:0;transition:width .3s}
  /* Result bars */
  .dim{margin-bottom:14px}
  .dim .lab{display:flex;justify-content:space-between;font-size:13.5px;margin-bottom:6px}
  .dim .lab b{font-weight:600}
  .dim .lab span{color:var(--sage-deep);font-weight:700}
  .meter{height:10px;background:var(--paper-2);border-radius:99px;overflow:hidden}
  .meter i{display:block;height:100%;border-radius:99px;background:linear-gradient(90deg,var(--sage-deep),var(--gold))}
  .band{display:inline-block;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gold-deep);background:rgba(194,161,95,.14);padding:4px 10px;border-radius:99px;margin-bottom:10px}
  .score-big{font-family:var(--serif);font-size:52px;line-height:1;font-weight:600}
  .guide{font-size:14px;color:var(--ink-soft);line-height:1.55;margin-top:6px}
  /* Journal */
  textarea,input,select{width:100%;font-family:var(--sans);font-size:15px;color:var(--ink);
    background:var(--card);border:1.5px solid var(--line);border-radius:12px;padding:12px 14px;resize:vertical}
  textarea:focus,input:focus{outline:none;border-color:var(--sage)}
  .mood{display:flex;gap:8px;margin:10px 0}
  .mood button{flex:1;padding:9px 0;border:1.5px solid var(--line);background:var(--card);border-radius:10px;font-size:20px;cursor:pointer}
  .mood button.on{border-color:var(--gold);background:rgba(194,161,95,.12)}
  .entry{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:14px 16px;margin-bottom:10px}
  .entry .meta{display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--muted);margin-bottom:6px}
  .entry .meta .tag{color:var(--sage-deep);font-weight:600;letter-spacing:.04em;text-transform:uppercase;font-size:10.5px}
  .entry p{font-size:14.5px;line-height:1.5;white-space:pre-wrap}
  .entry .del{background:none;border:none;color:var(--muted);cursor:pointer;font-size:12px;padding:4px}
  .empty{text-align:center;color:var(--muted);padding:30px 10px;font-size:14px}
  .empty .ic{width:40px;height:40px;margin:0 auto 10px;color:var(--paper-2);display:block}
  /* Spark chart */
  .spark{width:100%;height:96px;margin-top:8px}
  /* Coaching */
  .svc{display:flex;gap:12px;align-items:flex-start;padding:14px 0;border-bottom:1px solid var(--line)}
  .svc:last-child{border-bottom:none}
  .svc .n{font-family:var(--serif);font-size:16px;font-weight:600}
  .svc .d{font-size:13px;color:var(--muted);line-height:1.45;margin-top:2px}
  .svc a{color:var(--gold-deep);font-weight:600;font-size:13px;text-decoration:none;white-space:nowrap;margin-top:6px;display:inline-block}
  .practice{border:1px solid var(--line);border-radius:14px;margin-bottom:10px;overflow:hidden;background:var(--card)}
  .practice summary{padding:14px 16px;cursor:pointer;font-family:var(--serif);font-size:16px;font-weight:600;list-style:none;display:flex;justify-content:space-between;align-items:center}
  .practice summary::-webkit-details-marker{display:none}
  .practice summary .plus{color:var(--sage-deep);font-size:20px;transition:.2s}
  .practice[open] summary .plus{transform:rotate(45deg)}
  .practice .body{padding:0 16px 16px;font-size:14px;color:var(--ink-soft);line-height:1.6}
  .practice .body .step{margin-top:8px}
  /* Install banner + modal */
  .install-banner{display:none;align-items:center;gap:11px;background:linear-gradient(155deg,#2b322a,#20241f);color:#f2eede;border-radius:14px;padding:11px 12px 11px 14px;margin-bottom:14px;box-shadow:var(--shadow)}
  .install-banner .ib-ic{width:34px;height:34px;flex:0 0 auto;border-radius:9px;background:rgba(194,161,95,.18);display:grid;place-items:center;color:var(--gold)}
  .install-banner .ib-tx{flex:1;font-size:12.5px;line-height:1.3}
  .install-banner .ib-tx b{display:block;font-family:var(--serif);font-size:14.5px;font-weight:600}
  .install-banner .ib-tx span{color:#c9c3ac}
  .install-banner .ib-go{flex:0 0 auto;background:var(--gold-deep);color:#20241f;border:none;font-weight:700;font-size:13px;padding:9px 14px;border-radius:10px;cursor:pointer}
  .install-banner .ib-x{flex:0 0 auto;background:none;border:none;color:#9a9683;font-size:19px;line-height:1;cursor:pointer;padding:2px 4px}
  .modal-ov{position:fixed;inset:0;background:rgba(20,22,18,.55);backdrop-filter:blur(3px);display:none;align-items:flex-end;justify-content:center;z-index:60}
  .modal-ov.show{display:flex}
  .modal{background:var(--card);width:100%;max-width:520px;border-radius:20px 20px 0 0;padding:24px 22px calc(24px + env(safe-area-inset-bottom));box-shadow:0 -10px 40px rgba(0,0,0,.25);animation:slideup .28s ease}
  @keyframes slideup{from{transform:translateY(28px);opacity:.5}to{transform:none;opacity:1}}
  .modal h3{font-family:var(--serif);font-size:21px;margin-bottom:6px}
  .modal p{font-size:14px;color:var(--muted);margin-bottom:16px}
  .modal ol{margin:0 0 18px 20px;font-size:15px;line-height:1.75}
  .modal ol b{font-weight:600}
  .modal .sh{display:inline-flex;vertical-align:-4px;margin:0 1px}

  /* Nav */
  nav{position:fixed;bottom:0;left:0;right:0;z-index:30;height:calc(var(--nav-h) + env(safe-area-inset-bottom));
    padding-bottom:env(safe-area-inset-bottom);
    background:rgba(255,253,248,.94);backdrop-filter:blur(12px);border-top:1px solid var(--line);
    max-width:520px;margin:0 auto;display:flex}
  nav button{flex:1;background:none;border:none;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;color:var(--muted);font-size:10.5px;font-weight:600;letter-spacing:.02em}
  nav button svg{width:23px;height:23px;stroke-width:1.7}
  nav button.on{color:var(--ink)}
  nav button.on svg{color:var(--sage-deep)}
  .toast{position:fixed;bottom:calc(var(--nav-h) + 20px);left:50%;transform:translateX(-50%) translateY(20px);
    background:var(--ink);color:var(--paper);padding:12px 20px;border-radius:99px;font-size:13.5px;font-weight:600;
    opacity:0;pointer-events:none;transition:.3s;z-index:50;box-shadow:var(--shadow);white-space:nowrap}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  .divider{display:flex;align-items:center;gap:12px;color:var(--muted);font-size:11px;letter-spacing:.14em;text-transform:uppercase;margin:20px 0 12px}
  .divider:before,.divider:after{content:"";flex:1;height:1px;background:var(--line)}
  a.plainlink{color:var(--gold-deep);font-weight:600;text-decoration:none}
</style>
</head>
<body>
<div id="app">
  <header>
    <div class="mono">M</div>
    <div class="brand"><b>Maturity Coach</b><span id="greeting">Lead wisely · Live fully</span></div>
  </header>
  <main>
    <!-- TODAY -->
    <section class="view active" id="v-today">
      <div class="install-banner" id="install-banner">
        <div class="ib-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v11M8 10l4 4 4-4"/><path d="M5 21h14"/></svg></div>
        <div class="ib-tx"><b>Install this app</b><span>Add it to your home screen — works offline.</span></div>
        <button class="ib-go" onclick="onInstallClick()">Install</button>
        <button class="ib-x" onclick="dismissInstall()" aria-label="Dismiss">&times;</button>
      </div>
      <div class="card hero">
        <div class="eyebrow">Today&rsquo;s Wisdom</div>
        <div class="quote" id="q-text"></div>
        <div class="attr" id="q-attr"></div>
        <div class="prompt"><em>Reflect</em><span id="q-prompt"></span></div>
      </div>
      <div class="row" style="margin-bottom:14px">
        <button class="btn sage sm" style="flex:1" onclick="openReflection()">Write a reflection</button>
        <button class="btn ghost sm" style="flex:0 0 auto" onclick="newQuote()" title="Another">↻ Another</button>
      </div>
      <div class="stats">
        <div class="stat"><b id="s-streak">0</b><span>Day streak</span></div>
        <div class="stat"><b id="s-entries">0</b><span>Reflections</span></div>
        <div class="stat"><b id="s-score">&mdash;</b><span>Maturity</span></div>
      </div>
      <div class="eyebrow">Continue your practice</div>
      <div class="quick">
        <div class="tile" onclick="go('assess')">
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/><path d="M15 9l-3 3-1.5-1.5"/></svg>
          <b>Maturity Check</b><span>See where you stand across the five dimensions.</span>
        </div>
        <div class="tile" onclick="go('journal')">
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 5a2 2 0 0 1 2-2h11v18H6a2 2 0 0 1-2-2z"/><path d="M8 7h6M8 11h6"/></svg>
          <b>Journal</b><span>Capture what&rsquo;s alive in your leadership today.</span>
        </div>
        <div class="tile" onclick="go('progress')">
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 19V5M4 19h16"/><path d="M8 15l3-4 3 2 4-6"/></svg>
          <b>Progress</b><span>Watch your growth take shape over time.</span>
        </div>
        <div class="tile" onclick="go('coaching')">
          <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M21 15a2 2 0 0 1-2 2H8l-4 3V6a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2z"/></svg>
          <b>Coaching</b><span>Work with Eugene &mdash; sessions &amp; practices.</span>
        </div>
      </div>
    </section>

    <!-- ASSESS -->
    <section class="view" id="v-assess">
      <div class="eyebrow">The Maturity Method</div>
      <h2 class="title">Maturity Self-Assessment</h2>
      <p class="sub">A short, honest look at how you lead and live across five dimensions. Answer from how things truly are &mdash; not how you wish them to be.</p>
      <div id="assess-intro">
        <div class="card">
          <p style="font-size:14.5px;line-height:1.6;color:var(--ink-soft)">Fifteen statements, about three minutes. You&rsquo;ll get a maturity profile with tailored guidance, saved privately on your device so you can track how it shifts over time.</p>
        </div>
        <button class="btn" onclick="startAssess()">Begin the assessment</button>
        <div id="last-result-note" class="sub" style="text-align:center;margin-top:12px"></div>
      </div>
      <div id="assess-quiz" style="display:none">
        <div class="progressbar"><i id="quiz-bar"></i></div>
        <div id="quiz-q"></div>
        <div class="row">
          <button class="btn ghost" id="quiz-back" onclick="quizBack()">Back</button>
        </div>
      </div>
      <div id="assess-result" style="display:none"></div>
    </section>

    <!-- JOURNAL -->
    <section class="view" id="v-journal">
      <div class="eyebrow">Your Practice</div>
      <h2 class="title">Journal</h2>
      <p class="sub">A private space. Nothing here leaves your device.</p>
      <div class="card">
        <textarea id="j-text" rows="3" placeholder="What&rsquo;s asking for your attention as a leader today?"></textarea>
        <div class="mood" id="j-mood">
          <button data-m="1" title="Heavy">😔</button>
          <button data-m="2" title="Low">🙂</button>
          <button data-m="3" title="Steady">😌</button>
          <button data-m="4" title="Clear">😊</button>
          <button data-m="5" title="Alive">✨</button>
        </div>
        <button class="btn" onclick="saveJournal()">Save entry</button>
      </div>
      <div id="j-list"></div>
    </section>

    <!-- PROGRESS -->
    <section class="view" id="v-progress">
      <div class="eyebrow">The Long Road</div>
      <h2 class="title">Progress</h2>
      <p class="sub">Maturity is cultivated, not achieved. Here&rsquo;s your movement over time.</p>
      <div class="stats">
        <div class="stat"><b id="p-streak">0</b><span>Day streak</span></div>
        <div class="stat"><b id="p-entries">0</b><span>Reflections</span></div>
        <div class="stat"><b id="p-checks">0</b><span>Check-ins</span></div>
      </div>
      <div class="card">
        <div class="eyebrow">Maturity over time</div>
        <div id="p-chart"></div>
      </div>
      <div class="card" id="p-latest"></div>
    </section>

    <!-- COACHING -->
    <section class="view" id="v-coaching">
      <div class="eyebrow">Work With Eugene</div>
      <h2 class="title">Coaching</h2>
      <p class="sub">Ancient wisdom, modern intelligence, and the courage to live fully &mdash; while building something extraordinary.</p>
      <div class="card hero" style="margin-bottom:16px">
        <div class="eyebrow">Begin the journey</div>
        <div class="quote" style="font-size:19px">Start with a 30-minute exploratory conversation.</div>
        <div class="attr">No obligation, no agenda &mdash; just honest dialogue about what&rsquo;s possible.</div>
        <a id="book-btn" class="btn gold" style="margin-top:16px" href="https://cal.com/nkomba/30min" target="_blank" rel="noopener">Request Confidential Consultation</a>
      </div>
      <div class="card">
        <div class="eyebrow">Ways to work together</div>
        <div id="services"></div>
      </div>
      <div class="divider">Wisdom Practices</div>
      <div id="practices"></div>
      <button class="btn sage" id="install-btn-2" style="margin-top:4px;display:none" onclick="onInstallClick()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v11M8 10l4 4 4-4"/><path d="M5 21h14"/></svg>
        Install this app on your phone
      </button>
      <a class="btn ghost" href="https://maturity.coach" target="_blank" rel="noopener" style="margin-top:10px">Visit maturity.coach</a>
      <div style="text-align:center;margin-top:16px">
        <a class="plainlink" href="https://maturity.coach/privacy.html" target="_blank" rel="noopener" style="font-size:12.5px">Privacy Policy</a>
      </div>
    </section>
  </main>

  <nav>
    <button class="on" data-v="today" onclick="go('today')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19"/></svg>Today
    </button>
    <button data-v="assess" onclick="go('assess')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="9"/><path d="M15.5 8.5l-2.2 5-5 2.2 2.2-5z"/></svg>Assess
    </button>
    <button data-v="journal" onclick="go('journal')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 5a2 2 0 0 1 2-2h11v18H6a2 2 0 0 1-2-2z"/><path d="M8 7h6M8 11h6M8 15h4"/></svg>Journal
    </button>
    <button data-v="progress" onclick="go('progress')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 19V5M4 19h16"/><path d="M8 15l3-4 3 2 4-6"/></svg>Progress
    </button>
    <button data-v="coaching" onclick="go('coaching')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 15a2 2 0 0 1-2 2H8l-4 3V6a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2z"/></svg>Coaching
    </button>
  </nav>
</div>
<div class="toast" id="toast"></div>

<!-- iOS install instructions -->
<div class="modal-ov" id="ios-modal" onclick="if(event.target===this)closeIosHelp()">
  <div class="modal">
    <h3>Add to your Home Screen</h3>
    <p>In Safari, install Maturity Coach in two quick taps:</p>
    <ol>
      <li>Tap the <b>Share</b> icon <span class="sh"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a8863f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15V4M8.5 7.5 12 4l3.5 3.5"/><path d="M6 12v7a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-7"/></svg></span> at the bottom of the screen.</li>
      <li>Scroll down and choose <b>Add to Home Screen</b>, then tap <b>Add</b>.</li>
    </ol>
    <button class="btn" onclick="closeIosHelp()">Got it</button>
  </div>
</div>

<script>
/* ---------- Config ----------
   Your Cal.com scheduling link. Replace the URL below with your real event
   link, e.g. "https://cal.com/nkomba/30min". It is used by the
   "Request Confidential Consultation" button. */
const BOOKING_URL = "https://cal.com/nkomba/30min";

/* ---------- Storage ---------- */
const DB={
  get(k,f){try{return JSON.parse(localStorage.getItem('mc_'+k))??f}catch(e){return f}},
  set(k,v){localStorage.setItem('mc_'+k,JSON.stringify(v))}
};
const todayKey=()=> new Date().toISOString().slice(0,10);
const daysSinceEpoch=()=> Math.floor(Date.now()/864e5);

/* ---------- Content: daily wisdom ---------- */
const QUOTES=[
 {q:"Know thyself.",a:"Socrates",t:"Ancient Greece",p:"Where in your leadership are you performing a version of yourself, rather than living as who you truly are?"},
 {q:"The journey of a thousand miles begins with a single step.",a:"Laozi",t:"Taoism",p:"What is the one small step you have been postponing? Name it, and take it today."},
 {q:"As a man thinketh in his heart, so is he.",a:"Proverbs 23:7",t:"Wisdom Literature",p:"What belief about yourself are you quietly rehearsing? Is it worthy of you?"},
 {q:"Waste no more time arguing about what a good leader should be. Be one.",a:"Marcus Aurelius",t:"Stoicism",p:"What would the mature version of you simply do, without debate, in the next hour?"},
 {q:"I am because we are.",a:"Ubuntu",t:"African Philosophy",p:"Whose flourishing is bound up with yours? How will you tend to it this week?"},
 {q:"You have power over your mind — not outside events. Realize this, and you will find strength.",a:"Marcus Aurelius",t:"Stoicism",p:"What are you spending energy trying to control that was never yours to control?"},
 {q:"Mastering others is strength; mastering yourself is true power.",a:"Laozi",t:"Taoism",p:"Where is self-mastery the real work today — not managing others, but governing yourself?"},
 {q:"We suffer more often in imagination than in reality.",a:"Seneca",t:"Stoicism",p:"Which feared outcome is looming large in your mind but small in likelihood?"},
 {q:"It is not that we have a short time to live, but that we waste much of it.",a:"Seneca",t:"Stoicism",p:"If this quarter were your last, what would you stop doing immediately?"},
 {q:"No one is free who is not master of himself.",a:"Epictetus",t:"Stoicism",p:"What impulse, if you governed it well today, would set the tone for everything else?"},
 {q:"Guard your heart above all else, for it determines the course of your life.",a:"Proverbs 4:23",t:"Wisdom Literature",p:"What are you letting into your heart and mind that is quietly shaping your direction?"},
 {q:"Where there is no vision, the people perish.",a:"Proverbs 29:18",t:"Wisdom Literature",p:"Can those you lead clearly see the future you are building? When did you last say it aloud?"},
 {q:"Iron sharpens iron, so one person sharpens another.",a:"Proverbs 27:17",t:"Wisdom Literature",p:"Who sharpens you? Have you made room for that friction lately?"},
 {q:"If you want to go fast, go alone. If you want to go far, go together.",a:"African Proverb",t:"Ubuntu",p:"Where have you been going fast and alone when the work asks you to go far, together?"},
 {q:"Nature does not hurry, yet everything is accomplished.",a:"Laozi",t:"Taoism",p:"What would change if you trusted the right pace instead of forcing the fast one?"},
 {q:"The impediment to action advances action. What stands in the way becomes the way.",a:"Marcus Aurelius",t:"Stoicism",p:"What obstacle in front of you might actually be the path, if you turned toward it?"},
 {q:"At the center of your being you have the answer; you know who you are and what you want.",a:"Laozi",t:"Taoism",p:"Sit quietly for a moment. What do you already know that you have been avoiding?"},
 {q:"Fall seven times, stand up eight.",a:"Japanese Proverb",t:"Eastern Wisdom",p:"Where do you need to rise once more — not dramatically, just faithfully?"},
 {q:"What we do now echoes in eternity.",a:"Marcus Aurelius",t:"Stoicism",p:"What ordinary act today would you be proud to have echo beyond you?"},
 {q:"When there is no enemy within, the enemies without cannot hurt you.",a:"African Proverb",t:"Ubuntu",p:"What inner conflict is costing you more than any external one right now?"},
 {q:"Very little is needed to make a happy life; it is all within your way of thinking.",a:"Marcus Aurelius",t:"Stoicism",p:"What abundance is already present that your striving keeps you from seeing?"},
 {q:"The superior person is modest in speech but exceeds in action.",a:"Confucius",t:"Confucianism",p:"Where could you speak less and deliver more this week?"},
 {q:"He who conquers himself is the mightiest warrior.",a:"Confucius",t:"Confucianism",p:"What victory over yourself would matter more than any external win today?"},
 {q:"Smooth seas do not make skillful sailors.",a:"African Proverb",t:"Ubuntu",p:"What is this hard season teaching you that ease never could?"},
 {q:"Plans fail for lack of counsel, but with many advisers they succeed.",a:"Proverbs 15:22",t:"Wisdom Literature",p:"Whose counsel have you been avoiding because you suspect they are right?"},
 {q:"The best fighter is never angry.",a:"Laozi",t:"Taoism",p:"Where is your composure the leadership move today?"},
 {q:"The tongue has the power of life and death.",a:"Proverbs 18:21",t:"Wisdom Literature",p:"What life-giving word could you speak today that someone needs to hear?"},
 {q:"Waste no time debating. Turn inward and become the person you are meant to be.",a:"Marcus Aurelius",t:"Stoicism",p:"Who are you becoming — and is today an argument for it or against it?"}
];
let quoteOffset=0;
function currentQuote(){return QUOTES[(daysSinceEpoch()+quoteOffset)%QUOTES.length];}
function renderQuote(){
  const c=currentQuote();
  document.getElementById('q-text').textContent='“'+c.q+'”';
  document.getElementById('q-attr').innerHTML='<b>'+c.a+'</b> · '+c.t;
  document.getElementById('q-prompt').textContent=c.p;
}
function newQuote(){quoteOffset++;renderQuote();}

/* ---------- Assessment ---------- */
const DIMS=[
 {key:"self",name:"Self-Knowledge",force:"Ancient Wisdom",qs:[
   "I understand what truly drives my decisions, even the uncomfortable motives.",
   "I can name my core values and I lead in a way that honours them.",
   "I notice my emotional reactions early, before they run me."]},
 {key:"agency",name:"Agency & Clarity",force:"Neuroscience",qs:[
   "I respond to pressure with intention rather than reactivity.",
   "I give my attention to what I can influence and release what I cannot.",
   "My daily actions are clearly connected to what matters most to me."]},
 {key:"ubuntu",name:"Relationships & Ubuntu",force:"Ancient Wisdom",qs:[
   "The people I lead would say they feel genuinely seen by me.",
   "I build others&rsquo; strength rather than depending on their weakness.",
   "I actively seek counsel and let it change my mind."]},
 {key:"tech",name:"Wise Use of Technology",force:"Modern Technology",qs:[
   "I use technology and AI as tools for human flourishing, not as a crutch.",
   "I protect focused, undistracted time for the work that matters.",
   "I stay curious and current without letting the noise erode my judgement."]},
 {key:"life",name:"Sustainable Living",force:"Live Fully",qs:[
   "I am building my business without sacrificing the life I most want.",
   "I rest and recover on purpose, not only when I collapse.",
   "If nothing changed for five years, I would still be glad of this life."]}
];
const GUIDE={
 self:["Begin with honest self-inquiry — a daily reflection is the smallest reliable step.","Your self-awareness is emerging. Name one value each day and notice where you honoured it.","You know yourself well. Deepen it by examining the motives beneath your best decisions.","Rare self-knowledge. Now use it to help others see themselves more clearly."],
 agency:["Reactivity is running more than you&rsquo;d like. Practice the pause — three breaths before you respond.","You&rsquo;re building agency. Each day, choose one thing to influence and one thing to release.","Strong intentional action. Guard it against the urgent crowding out the important.","You lead from clarity. Model the pause for those who lead reactively."],
 ubuntu:["Leadership is relational. Ask one person this week what they need to feel seen.","Your connection is growing. Shift from solving for people to strengthening them.","You lead through others generously. Keep seeking the counsel that changes your mind.","You embody Ubuntu. Your presence makes others more themselves — steward it widely."],
 tech:["Technology may be leading you. Reclaim one block of undistracted time daily.","You&rsquo;re finding balance with tech. Be deliberate about what earns your attention.","You wield technology wisely. Keep judgement upstream of the tools.","You bridge the human–tech gap masterfully — teach others to do the same."],
 life:["The business may be costing the life. Define what &lsquo;living fully&rsquo; means this season.","You&rsquo;re protecting your life more. Schedule recovery as seriously as work.","You&rsquo;re building sustainably. Keep testing every commitment against the life you want.","You lead wisely and live fully. This is the whole aim — help others believe it&rsquo;s possible."]
};
function band(s){return s<40?0:s<60?1:s<80?2:3;}
const BANDNAME=["Emerging","Developing","Maturing","Flourishing"];
let quiz=null;
function flatQs(){const a=[];DIMS.forEach(d=>d.qs.forEach((q,i)=>a.push({dim:d.key,dname:d.name,force:d.force,q})));return a;}
function startAssess(){
  quiz={items:flatQs(),answers:[],i:0};
  document.getElementById('assess-intro').style.display='none';
  document.getElementById('assess-result').style.display='none';
  document.getElementById('assess-quiz').style.display='block';
  renderQ();
}
function renderQ(){
  const it=quiz.items[quiz.i];
  document.getElementById('quiz-bar').style.width=((quiz.i)/quiz.items.length*100)+'%';
  const chosen=quiz.answers[quiz.i];
  let btns='';for(let v=1;v<=5;v++){btns+=`<button class="${chosen===v?'on':''}" onclick="answer(${v})">${v}</button>`;}
  document.getElementById('quiz-q').innerHTML=`
    <div class="q">
      <div class="dimtag">${it.force} &middot; ${it.dname}</div>
      <p>${quiz.i+1}. ${it.q}</p>
      <div class="scale">${btns}</div>
      <div class="scale-legend"><span>Rarely true</span><span>Very true</span></div>
    </div>`;
  document.getElementById('quiz-back').style.visibility=quiz.i===0?'hidden':'visible';
}
function answer(v){
  quiz.answers[quiz.i]=v;
  setTimeout(()=>{ if(quiz.i<quiz.items.length-1){quiz.i++;renderQ();} else finishAssess(); },180);
}
function quizBack(){if(quiz.i>0){quiz.i--;renderQ();}}
function finishAssess(){
  const scores={};DIMS.forEach(d=>scores[d.key]={sum:0,n:0});
  quiz.items.forEach((it,idx)=>{const v=quiz.answers[idx]||3;scores[it.dim].sum+=v;scores[it.dim].n++;});
  const dimScores=DIMS.map(d=>({key:d.key,name:d.name,score:Math.round(scores[d.key].sum/scores[d.key].n/5*100)}));
  const overall=Math.round(dimScores.reduce((a,b)=>a+b.score,0)/dimScores.length);
  const rec={date:new Date().toISOString(),overall,dims:dimScores};
  const hist=DB.get('assessments',[]);hist.push(rec);DB.set('assessments',hist);
  showResult(rec);refreshStats();
}
function showResult(rec){
  document.getElementById('assess-quiz').style.display='none';
  const el=document.getElementById('assess-result');el.style.display='block';
  const b=band(rec.overall);
  let bars=rec.dims.map(d=>`
    <div class="dim"><div class="lab"><b>${d.name}</b><span>${d.score}</span></div>
    <div class="meter"><i style="width:${d.score}%"></i></div></div>`).join('');
  let guides=rec.dims.map(d=>`<p class="guide"><b>${d.name}.</b> ${GUIDE[d.key][band(d.score)]}</p>`).join('');
  el.innerHTML=`
    <div class="card" style="text-align:center">
      <span class="band">${BANDNAME[b]}</span>
      <div class="score-big">${rec.overall}</div>
      <div class="sub" style="margin:6px 0 0">Overall Maturity Index</div>
    </div>
    <div class="card">${bars}</div>
    <div class="card"><div class="eyebrow">Your guidance</div>${guides}</div>
    <button class="btn sage" onclick="go('coaching')">Explore coaching with Eugene</button>
    <button class="btn ghost" style="margin-top:10px" onclick="resetAssess()">Retake assessment</button>`;
  el.scrollIntoView({behavior:'smooth',block:'start'});
}
function resetAssess(){
  document.getElementById('assess-result').style.display='none';
  document.getElementById('assess-intro').style.display='block';
  renderLastResult();
}
function renderLastResult(){
  const hist=DB.get('assessments',[]);const note=document.getElementById('last-result-note');
  if(hist.length){const last=hist[hist.length-1];
    note.innerHTML=`Last check-in: <b>${last.overall}</b> (${BANDNAME[band(last.overall)]}) · <a class="plainlink" style="cursor:pointer" onclick="viewSaved(${hist.length-1})">view</a>`;
  } else note.textContent='';
}
function viewSaved(i){const hist=DB.get('assessments',[]);if(hist[i])showResult(hist[i]);}

/* ---------- Journal ---------- */
let moodSel=0;
document.getElementById('j-mood').addEventListener('click',e=>{
  const b=e.target.closest('button');if(!b)return;
  [...document.querySelectorAll('#j-mood button')].forEach(x=>x.classList.remove('on'));
  b.classList.add('on');moodSel=+b.dataset.m;
});
function saveJournal(tagText){
  const ta=document.getElementById('j-text');const text=ta.value.trim();
  if(!text){toast('Write a few words first');return;}
  const entries=DB.get('journal',[]);
  entries.unshift({date:new Date().toISOString(),text,mood:moodSel||null,tag:tagText||'Reflection'});
  DB.set('journal',entries);ta.value='';moodSel=0;
  [...document.querySelectorAll('#j-mood button')].forEach(x=>x.classList.remove('on'));
  renderJournal();refreshStats();toast('Saved to your journal');
}
function delEntry(i){const e=DB.get('journal',[]);e.splice(i,1);DB.set('journal',e);renderJournal();refreshStats();}
function renderJournal(){
  const e=DB.get('journal',[]);const list=document.getElementById('j-list');
  if(!e.length){list.innerHTML=`<div class="empty"><svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 5a2 2 0 0 1 2-2h11v18H6a2 2 0 0 1-2-2z"/><path d="M8 8h6M8 12h6"/></svg>Your reflections will gather here.<br>Begin with today&rsquo;s prompt.</div>`;return;}
  const moods=['','😔','🙂','😌','😊','✨'];
  list.innerHTML=e.map((x,i)=>{
    const d=new Date(x.date);const ds=d.toLocaleDateString(undefined,{month:'short',day:'numeric',year:'numeric'});
    return `<div class="entry"><div class="meta"><span class="tag">${x.tag||'Reflection'} ${x.mood?('· '+moods[x.mood]):''}</span><span>${ds} · <button class="del" onclick="delEntry(${i})">Delete</button></span></div><p>${escapeHtml(x.text)}</p></div>`;
  }).join('');
}
function openReflection(){
  const c=currentQuote();
  go('journal');
  const ta=document.getElementById('j-text');
  ta.value='On “'+c.q+'” — '+c.a+'\n\n';
  ta.focus();ta.setSelectionRange(ta.value.length,ta.value.length);
}
function escapeHtml(s){return s.replace(/[&<>]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]));}

/* ---------- Progress ---------- */
function computeStreak(){
  const e=DB.get('journal',[]);if(!e.length)return 0;
  const days=new Set(e.map(x=>x.date.slice(0,10)));
  let streak=0;let d=new Date();
  for(;;){const k=d.toISOString().slice(0,10);
    if(days.has(k)){streak++;d.setDate(d.getDate()-1);}
    else if(streak===0&&k===todayKey()){d.setDate(d.getDate()-1);} // allow no entry yet today
    else break;}
  return streak;
}
function refreshStats(){
  const entries=DB.get('journal',[]);const hist=DB.get('assessments',[]);
  const streak=computeStreak();
  const last=hist.length?hist[hist.length-1].overall:null;
  document.getElementById('s-streak').textContent=streak;
  document.getElementById('s-entries').textContent=entries.length;
  document.getElementById('s-score').textContent=last??'—';
  document.getElementById('p-streak').textContent=streak;
  document.getElementById('p-entries').textContent=entries.length;
  document.getElementById('p-checks').textContent=hist.length;
  renderChart();renderLatest();renderLastResult();
}
function renderChart(){
  const hist=DB.get('assessments',[]);const box=document.getElementById('p-chart');
  if(hist.length<1){box.innerHTML=`<p class="sub" style="margin:6px 0 0">Take the assessment to begin your growth curve.</p>`;return;}
  const pts=hist.slice(-8).map(h=>h.overall);
  const w=440,h=90,pad=6;const max=100,min=0;
  const step=pts.length>1?(w-pad*2)/(pts.length-1):0;
  const xy=pts.map((v,i)=>[pad+i*step,h-pad-(v-min)/(max-min)*(h-pad*2)]);
  const line=xy.map((p,i)=>(i?'L':'M')+p[0].toFixed(1)+' '+p[1].toFixed(1)).join(' ');
  const area=line+` L ${xy[xy.length-1][0].toFixed(1)} ${h-pad} L ${xy[0][0].toFixed(1)} ${h-pad} Z`;
  const dots=xy.map(p=>`<circle cx="${p[0].toFixed(1)}" cy="${p[1].toFixed(1)}" r="3.2" fill="#5f6e4e"/>`).join('');
  box.innerHTML=`<svg class="spark" viewBox="0 0 ${w} ${h}" preserveAspectRatio="none">
    <defs><linearGradient id="g" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#7d8c6a" stop-opacity=".35"/><stop offset="1" stop-color="#7d8c6a" stop-opacity="0"/></linearGradient></defs>
    <path d="${area}" fill="url(#g)"/><path d="${line}" fill="none" stroke="#5f6e4e" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>${dots}</svg>
    <div class="sub" style="text-align:center;margin:2px 0 0">Latest ${pts[pts.length-1]} · ${BANDNAME[band(pts[pts.length-1])]}</div>`;
}
function renderLatest(){
  const hist=DB.get('assessments',[]);const box=document.getElementById('p-latest');
  if(!hist.length){box.innerHTML=`<div class="eyebrow">Dimensions</div><p class="sub" style="margin:6px 0 0">Your five-dimension profile appears here after your first check-in.</p>`;return;}
  const last=hist[hist.length-1];
  const prev=hist.length>1?hist[hist.length-2]:null;
  const bars=last.dims.map(d=>{
    let delta='';if(prev){const pd=prev.dims.find(x=>x.key===d.key);if(pd){const diff=d.score-pd.score;if(diff)delta=` <span style="color:${diff>0?'#5f6e4e':'#a8863f'};font-weight:700">${diff>0?'▲':'▼'}${Math.abs(diff)}</span>`;}}
    return `<div class="dim"><div class="lab"><b>${d.name}</b><span>${d.score}${delta}</span></div><div class="meter"><i style="width:${d.score}%"></i></div></div>`;}).join('');
  box.innerHTML=`<div class="eyebrow">Latest profile${prev?' · vs previous':''}</div>${bars}`;
}

/* ---------- Coaching ---------- */
const SERVICES=[
 {n:"Executive Mastery Program",d:"Twelve months of deep, bespoke 1:1 coaching for senior leaders ready to step into the fullest expression of who they are."},
 {n:"The Maturity Circle",d:"An intimate cohort of peers navigating business excellence and a life they love — together."},
 {n:"Leadership Culture Design",d:"Transform your organisation&rsquo;s invisible culture into one where people bring their best and go home fulfilled."},
 {n:"Wisdom in the AI Era",d:"A provocative keynote on why human maturity is the greatest competitive advantage in an AI-driven world."}
];
const PRACTICES=[
 {n:"The Evening Review",s:"Stoicism",b:["At day&rsquo;s end, ask three questions Seneca practised nightly:","<div class='step'>1. What did I do well today?</div><div class='step'>2. Where did I fall short of who I want to be?</div><div class='step'>3. What will I do differently tomorrow?</div>","Write your answer in the Journal. Judge the action, not yourself."]},
 {n:"The Prefrontal Pause",s:"Neuroscience",b:["Before a charged response, engage the thinking brain over the reactive one:","<div class='step'>Breathe in for 4, hold for 4, out for 6 — three times.</div><div class='step'>Name the emotion silently: &lsquo;This is frustration.&rsquo;</div><div class='step'>Ask: what does the mature response look like here?</div>","The pause is where your agency lives."]},
 {n:"The Ubuntu Check-In",s:"African Wisdom",b:["Leadership is relational. Once this week, with one person you lead:","<div class='step'>Ask: &lsquo;What do you need from me that you&rsquo;re not getting?&rsquo;</div><div class='step'>Listen fully — do not defend or fix.</div><div class='step'>Thank them, and act on one thing.</div>","I am because we are."]},
 {n:"The Life-First Calendar",s:"Live Fully",b:["Reverse the usual order for next week:","<div class='step'>Block what matters in your life first — rest, family, health, meaning.</div><div class='step'>Then arrange the business around it.</div><div class='step'>Notice the resistance. That resistance is the lesson.</div>","You didn&rsquo;t build a business to be trapped by it."]},
 {n:"Naming Your Values",s:"Know Thyself",b:["Clarity of values precedes wise decisions:","<div class='step'>List the 5 values you most want to lead by.</div><div class='step'>For each, rate 1–5 how fully you lived it this month.</div><div class='step'>Choose the lowest one as this month&rsquo;s focus.</div>","Save the list in your Journal and revisit it monthly."]}
];
function renderCoaching(){
  document.getElementById('services').innerHTML=SERVICES.map(s=>`<div class="svc"><div><div class="n">${s.n}</div><div class="d">${s.d}</div><a href="https://maturity.coach/services.html" target="_blank" rel="noopener">Learn more →</a></div></div>`).join('');
  document.getElementById('practices').innerHTML=PRACTICES.map(p=>`<details class="practice"><summary>${p.n}<span class="plus">+</span></summary><div class="body"><div class="dimtag" style="font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--sage-deep);font-weight:600;margin-bottom:8px">${p.s}</div>${p.b.map(x=>`<div>${x}</div>`).join('')}<button class="btn ghost sm" style="margin-top:12px;width:100%" onclick="go('journal')">Open Journal</button></div></details>`).join('');
}

/* ---------- Router ---------- */
function go(v){
  document.querySelectorAll('.view').forEach(s=>s.classList.remove('active'));
  document.getElementById('v-'+v).classList.add('active');
  document.querySelectorAll('nav button').forEach(b=>b.classList.toggle('on',b.dataset.v===v));
  window.scrollTo({top:0,behavior:'instant'in window?'instant':'auto'});
  if(v==='progress')refreshStats();
}
let toastTimer;
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),1900);}

/* ---------- Greeting ---------- */
function setGreeting(){const h=new Date().getHours();const g=h<12?'Good morning':h<18?'Good afternoon':'Good evening';document.getElementById('greeting').textContent=g+' · lead wisely';}

/* ---------- Init ---------- */
renderQuote();renderJournal();renderCoaching();refreshStats();renderLastResult();setGreeting();
(function wireBooking(){var b=document.getElementById('book-btn');if(b)b.href=BOOKING_URL;})();

/* ---------- Install to Home Screen ---------- */
let deferredPrompt=null;
const mcStandalone=window.matchMedia('(display-mode: standalone)').matches||window.navigator.standalone===true;
const mcIOS=/iphone|ipad|ipod/i.test(navigator.userAgent);
function showInstallBanner(){
  if(mcStandalone)return;                              // already installed
  if(sessionStorage.getItem('mc_install_dismissed'))return;
  var b=document.getElementById('install-banner');if(b)b.style.display='flex';
}
function dismissInstall(){
  sessionStorage.setItem('mc_install_dismissed','1');
  var b=document.getElementById('install-banner');if(b)b.style.display='none';
}
function onInstallClick(){
  if(mcStandalone){toast('The app is already installed');return;}
  if(deferredPrompt){                                  // Android / desktop Chrome
    deferredPrompt.prompt();
    deferredPrompt.userChoice.finally(function(){
      deferredPrompt=null;
      var b=document.getElementById('install-banner');if(b)b.style.display='none';
    });
  } else {                                             // iOS (and fallback): show steps
    openIosHelp();
  }
}
function openIosHelp(){document.getElementById('ios-modal').classList.add('show');}
function closeIosHelp(){document.getElementById('ios-modal').classList.remove('show');}
window.addEventListener('beforeinstallprompt',function(e){e.preventDefault();deferredPrompt=e;showInstallBanner();});
window.addEventListener('appinstalled',function(){
  deferredPrompt=null;
  var b=document.getElementById('install-banner');if(b)b.style.display='none';
  toast('Installed — find it on your home screen');
});
if(mcIOS)showInstallBanner();                          // iOS never fires beforeinstallprompt
if(!mcStandalone){var ib2=document.getElementById('install-btn-2');if(ib2)ib2.style.display='flex';}  // show permanent Install button unless already installed

/* ---------- Service worker ---------- */
if('serviceWorker'in navigator){window.addEventListener('load',()=>navigator.serviceWorker.register('sw.js').catch(()=>{}));}
</script>
</body>
</html>
