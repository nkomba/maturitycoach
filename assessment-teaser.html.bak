<!-- ═══════════════ SCRIPTS ═══════════════ -->
 <script src="js/tracking.js"></script>
<script>
(function() {
    'use strict';

    // ── TEASER DATA (5 questions from the full 15) ──
    var TEASER_QUESTIONS = [
        {
            id: 1, dimension: 'Emotional Intelligence',
            text: 'When you experience strong emotions at work, what happens?',
            options: [
                { value: 1, text: 'They spill over and affect my behavior before I notice.' },
                { value: 2, text: 'I notice them but struggle to regulate in the moment.' },
                { value: 3, text: 'I recognize, name, and manage my emotions effectively.' },
                { value: 4, text: 'I use my emotional awareness to coach others through theirs.' }
            ]
        },
        {
            id: 2, dimension: 'Decision-Making',
            text: 'How would you describe your decision-making process?',
            options: [
                { value: 1, text: 'I rely primarily on intuition or past experience.' },
                { value: 2, text: 'I consult a few trusted colleagues before deciding.' },
                { value: 3, text: 'I use structured frameworks and seek diverse input.' },
                { value: 4, text: 'I balance data, intuition, stakeholder needs, and long-term impact.' }
            ]
        },
        {
            id: 3, dimension: 'Self-Awareness',
            text: 'How well do you understand your own leadership patterns and blind spots?',
            options: [
                { value: 1, text: 'I haven\'t spent much time reflecting on this.' },
                { value: 2, text: 'I know my strengths but am less clear on my blind spots.' },
                { value: 3, text: 'I actively seek to understand my patterns through reflection and feedback.' },
                { value: 4, text: 'I have deep, ongoing self-inquiry practices and visibly work on my edges.' }
            ]
        },
        {
            id: 4, dimension: 'Delegation & Trust',
            text: 'How do you approach delegating important work?',
            options: [
                { value: 1, text: 'I keep critical tasks because others might not do them right.' },
                { value: 2, text: 'I delegate tasks but micromanage the execution.' },
                { value: 3, text: 'I delegate outcomes with clear expectations and check-ins.' },
                { value: 4, text: 'I delegate authority, not just tasks, and grow others\' capabilities.' }
            ]
        },
        {
            id: 5, dimension: 'Systems Thinking',
            text: 'When solving problems, how do you consider broader systems and interconnections?',
            options: [
                { value: 1, text: 'I solve the immediate problem in front of me.' },
                { value: 2, text: 'I look at adjacent areas but may miss downstream effects.' },
                { value: 3, text: 'I map stakeholders, dependencies, and unintended consequences.' },
                { value: 4, text: 'I redesign systems themselves, addressing root causes and feedback loops.' }
            ]
        }
    ];

    var TEASER_BANDS = [
        { min: 5, max: 8, label: 'Emerging Leader',
          desc: 'You\'re at the beginning of a deliberate leadership journey. You have raw potential and genuine willingness to grow. The full assessment can reveal exactly where to focus first.' },
        { min: 9, max: 12, label: 'Developing Leader',
          desc: 'You\'ve built a foundation and are growing in self-awareness. You handle many situations well but may struggle under pressure. The full assessment maps your growth edges in detail.' },
        { min: 13, max: 16, label: 'Practicing Leader',
          desc: 'You demonstrate consistent leadership maturity. The next edge is systems-level impact. The full assessment identifies which dimensions to deepen.' },
        { min: 17, max: 20, label: 'Mastery-Level Leader',
          desc: 'You operate from deep integration — wisdom, presence, and systemic awareness. The full assessment helps you refine your legacy and mentor others.' }
    ];

    var SCALE_LABELS = ['Emerging', 'Developing', 'Practicing', 'Mastery'];

    // ── STATE ──
    var questions = TEASER_QUESTIONS;
    var totalQuestions = questions.length;
    var currentIndex = 0;
    var answers = {};

    // ── DOM ──
    var els = {
        start: document.getElementById('teaserStart'),
        interface: document.getElementById('teaserInterface'),
        results: document.getElementById('teaserResults'),
        body: document.getElementById('teaserBody'),
        begin: document.getElementById('teaserBeginBtn'),
        prev: document.getElementById('teaserPrev'),
        next: document.getElementById('teaserNext'),
        submit: document.getElementById('teaserSubmit'),
        progress: document.getElementById('teaserProgress'),
        step: document.getElementById('teaserStep'),
        score: document.getElementById('teaserScore'),
        bandLabel: document.getElementById('teaserBandLabel'),
        bandDesc: document.getElementById('teaserBandDesc'),
            // Add to els object:
        emailGate: document.getElementById('teaserEmailGate'),
        revealBtn: document.getElementById('teaserRevealBtn'),
        userEmail: document.getElementById('teaserEmail'),
        emailError: document.getElementById('teaserEmailError'),

        dimensions: document.getElementById('teaserDimensions')
    };

    // ── EVENTS ──
    if (els.begin) {
        els.begin.addEventListener('click', function(e) {
            if (e) e.preventDefault();
            beginQuiz();
        });
    }
    if (els.prev) els.prev.addEventListener('click', goPrev);
    if (els.next) els.next.addEventListener('click', goNext);
    if (els.submit) els.submit.addEventListener('click', submitQuiz);
        // Add event binding after existing bindings:
    if (els.revealBtn) {
        els.revealBtn.addEventListener('click', function(e) {
            if (e) e.preventDefault();
            revealResults();
        });
    }
    if (els.userEmail) {
        els.userEmail.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                revealResults();
            }
        });
    }


    // ── FUNCTIONS ──
    function beginQuiz() {
          if (window.AssessmentTracking) {
        AssessmentTracking.start('teaser');
    }
        if (els.start) els.start.style.display = 'none';
    if (els.interface) els.interface.style.display = 'block';
        if (els.start) els.start.style.display = 'none';
        if (els.interface) els.interface.style.display = 'block';
        renderQuestion();
        updateProgress();
    }

    function renderQuestion() {
        var q = questions[currentIndex];
        els.body.innerHTML = '';

        var card = document.createElement('div');

        var dim = document.createElement('span');
        dim.className = 'teaser-dimension';
        dim.textContent = q.dimension;
        card.appendChild(dim);

        var title = document.createElement('h2');
        title.className = 'teaser-question';
        title.textContent = q.text;
        card.appendChild(title);

        var opts = document.createElement('div');
        opts.className = 'teaser-options';

        q.options.forEach(function(opt) {
            var optDiv = document.createElement('div');
            optDiv.className = 'teaser-option';
            if (answers[q.id] === opt.value) optDiv.classList.add('selected');

            optDiv.innerHTML = '<span class="teaser-option-radio"></span><span>' + opt.text + '</span>';

            optDiv.addEventListener('click', function() {
                answers[q.id] = opt.value;
                renderQuestion();
            });

            opts.appendChild(optDiv);
        });

        card.appendChild(opts);
        els.body.appendChild(card);

        if (els.prev) els.prev.disabled = currentIndex === 0;
        if (els.next) els.next.style.display = currentIndex === totalQuestions - 1 ? 'none' : 'inline-block';
        if (els.submit) els.submit.style.display = currentIndex === totalQuestions - 1 ? 'inline-block' : 'none';
    }

    function updateProgress() {
        var pct = ((currentIndex + 1) / totalQuestions) * 100;
        if (els.progress) els.progress.style.width = pct + '%';
        if (els.step) els.step.textContent = 'Question ' + (currentIndex + 1) + ' of ' + totalQuestions;
    }

    function goNext() {
        if (!answers[questions[currentIndex].id]) {
            alert('Please select an answer first.');
            return;
        }
        if (currentIndex < totalQuestions - 1) {
            currentIndex++;
            renderQuestion();
            updateProgress();
        }
    }

    function goPrev() {
        if (currentIndex > 0) {
            currentIndex--;
            renderQuestion();
            updateProgress();
        }
    }

    // Replace submitQuiz():
    function submitQuiz() {
        var unanswered = questions.filter(function(q) { return answers[q.id] === undefined; });
        if (unanswered.length > 0) {
            alert('Please answer all questions first.');
            return;
        }

        var score = 0;
        questions.forEach(function(q) { score += answers[q.id] || 0; });

        // Show email gate instead of results
        if (els.interface) els.interface.style.display = 'none';
        if (els.emailGate) els.emailGate.style.display = 'block';

        if (els.emailGate) {
            els.emailGate.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        if (els.userEmail) {
            setTimeout(function() { els.userEmail.focus(); }, 600);
        }
    }

    function validateEmail(email) {
        var re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return re.test(email);
    }

    function revealResults() {
        var email = els.userEmail ? els.userEmail.value.trim() : '';

        if (!validateEmail(email)) {
            if (els.emailError) els.emailError.style.display = 'block';
            if (els.userEmail) {
                els.userEmail.style.borderColor = '#c64949';
                setTimeout(function() {
                    els.userEmail.style.borderColor = '';
                }, 2000);
            }
            return;
        }

        if (els.emailError) els.emailError.style.display = 'none';

        // Track with email
        var score = 0;
        questions.forEach(function(q) { score += answers[q.id] || 0; });

        if (window.AssessmentTracking) {
            AssessmentTracking.complete('teaser', score, email);
        }

        // Store email as lead
        var leads = JSON.parse(localStorage.getItem('maturity_leads') || '[]');
        leads.push({
            email: email,
            type: 'teaser',
            score: score,
            date: new Date().toISOString()
        });
        localStorage.setItem('maturity_leads', JSON.stringify(leads));

        // Hide gate, show results
        if (els.emailGate) els.emailGate.style.display = 'none';
        if (els.results) els.results.style.display = 'block';
        if (els.results) els.results.scrollIntoView({ behavior: 'smooth', block: 'start' });

        showResults(score);
    }

})();

// Mobile menu
function toggleMenu() {
    document.getElementById('mobileMenu').classList.toggle('open');
}

// Fade-up observer
var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.12 });
document.querySelectorAll('.fade-up').forEach(function(el) { observer.observe(el); });
</script>

</body>
</html>