<!-- ═══════════════ HERO ═══════════════ -->
<section class="teaser-hero">
  <div class="teaser-hero-bg"></div>
  <div class="teaser-hero-inner">
    <div class="fade-up">
      <div class="teaser-hero-title">Quick Leadership Check</div>
      <h1 class="display-2">How Mature Is Your Leadership?</h1>
      <p>Five questions. Two minutes. A snapshot of where you stand — and where your greatest growth edge lives.</p>
      <div class="teaser-meta">5 questions · ~2 minutes · Instant results</div>
      <a href="#takeTeaser" class="btn btn-gold btn-lg">Take the Quick Check</a>
    </div>
  </div>
</section>

<!-- ═══════════════ QUIZ SECTION ═══════════════ -->
<section class="teaser-section" id="takeTeaser">
  <div class="teaser-container">
    <div class="teaser-wrap fade-up">

      <!-- START SCREEN -->
      <div id="teaserStart" class="teaser-start">
        <p>This is a quick snapshot — not the full assessment. Five questions across five core leadership dimensions. Your results are instant and confidential.</p>
        <div class="divider"></div>
        <button id="teaserBeginBtn" class="btn btn-gold btn-lg">Start Quick Check</button>
      </div>

      <!-- QUIZ INTERFACE -->
      <div id="teaserInterface" style="display:none;">
        <div class="teaser-progress-bar">
          <div id="teaserProgress" class="teaser-progress-fill"></div>
        </div>
        <div id="teaserStep" class="teaser-step">Question 1 of 5</div>
        <div id="teaserBody"></div>
        <div class="teaser-nav">
          <button id="teaserPrev" class="teaser-btn teaser-btn-back" disabled>← Previous</button>
          <button id="teaserNext" class="teaser-btn teaser-btn-next">Next →</button>
          <button id="teaserSubmit" class="teaser-btn teaser-btn-next" style="display:none;">See My Snapshot</button>
        </div>
      </div>

            <!-- EMAIL GATE -->
      <div id="teaserEmailGate" style="display:none;" class="teaser-result">
        <div class="email-gate-icon">✉</div>
        <h2 class="teaser-result-label" style="margin-bottom: 12px;">Your Snapshot Is Ready</h2>
        <p class="teaser-result-desc" style="margin-bottom: 28px;">
          Enter your email to see your leadership maturity snapshot — plus get access to the full 15-question assessment.
        </p>
        <div style="max-width: 400px; margin: 0 auto;">
          <div class="form-group" style="text-align: left;">
            <label for="teaserEmail">Email Address</label>
            <input type="email" id="teaserEmail" placeholder="you@example.com" style="background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.15); color: var(--white);" />
          </div>
          <p id="teaserEmailError" style="color: #c64949; font-size: 13px; display: none; margin-bottom: 12px;">Please enter a valid email address.</p>
          <button id="teaserRevealBtn" class="btn btn-gold btn-lg" style="width: 100%; margin-bottom: 16px;">Reveal My Snapshot</button>
          <p style="font-size: 12px; color: rgba(255,255,255,0.4); line-height: 1.5;">
            We respect your privacy. Your email will never be shared. Unsubscribe anytime.
          </p>
        </div>
      </div>

      <!-- RESULTS -->
      <div id="teaserResults" style="display:none;" class="teaser-result">
        <div class="teaser-score-ring">
          <div id="teaserScore" class="teaser-score-inner">0/20</div>
        </div>
        <div id="teaserBandLabel" class="teaser-result-label">Emerging Leader</div>
        <div id="teaserBandDesc" class="teaser-result-desc"></div>

        <div id="teaserDimensions" class="teaser-dimensions"></div>

        <div class="teaser-upsell">
          <div class="teaser-upsell-title">This is just the beginning.</div>
          <div class="teaser-upsell-text">
            The full Leadership Maturity Assessment covers 15 dimensions — including conflict resolution, ethical leadership, resilience, vision-building, and more. It takes 10 minutes and provides a complete map of your leadership profile.
          </div>
          <div class="teaser-upsell-features">
            <span class="teaser-upsell-feature">15 dimensions</span>
            <span class="teaser-upsell-feature">Personalized recommendations</span>
            <span class="teaser-upsell-feature">Dimension-by-dimension breakdown</span>
          </div>
          <div class="teaser-result-cta">
            <a href="assessment.html" class="btn btn-gold btn-lg">Take the Full Assessment</a>
            <a href="contact.html" class="btn teaser-btn-back">Book a Discovery Session</a>
          </div>
        </div>

