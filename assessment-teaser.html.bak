<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Quick Leadership Check — maturity.coach</title>
  <meta name="description" content="A 2-minute leadership maturity check — 5 questions to discover your leadership profile." />
  <link rel="stylesheet" href="style.css" />
  <style>
    /* ── TEASER PAGE SPECIFIC ── */

    .teaser-hero {
      min-height: 60vh;
      background: var(--charcoal);
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding-top: var(--nav-height);
    }

    .teaser-hero-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 80% at 80% 40%, rgba(184,151,90,0.1) 0%, transparent 60%);
    }

    .teaser-hero-inner {
      position: relative;
      z-index: 2;
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 60px 32px;
      text-align: center;
      width: 100%;
    }

    .teaser-hero h1 { color: var(--white); margin-bottom: 16px; }
    .teaser-hero-title { color: var(--gold); font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 24px; }
    .teaser-hero p { color: rgba(255,255,255,0.65); max-width: 520px; margin: 0 auto 24px; font-size: 18px; line-height: 1.65; font-weight: 300; }
    .teaser-meta { font-size: 13px; color: rgba(255,255,255,0.45); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 36px; }

    .teaser-section { background: var(--charcoal); color: var(--white); padding: 60px 0 100px; }
    .teaser-container { max-width: 680px; margin: 0 auto; padding: 0 32px; }

    .teaser-wrap {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: var(--radius-lg);
      padding: 48px 40px;
      min-height: 360px;
    }

    /* Start Screen */
    .teaser-start { text-align: center; padding: 20px 0; }
    .teaser-start p { color: rgba(255,255,255,0.6); font-size: 16px; line-height: 1.7; margin: 0 auto 32px; max-width: 440px; }

    /* Progress */
    .teaser-progress-bar { width: 100%; height: 4px; background: rgba(255,255,255,0.10); border-radius: 2px; margin-bottom: 28px; overflow: hidden; }
    .teaser-progress-fill { height: 100%; background: linear-gradient(90deg, var(--gold-dark), var(--gold)); border-radius: 2px; transition: width 0.4s ease; width: 0%; }
    .teaser-step { font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 20px; text-align: right; }

    /* Question */
    .teaser-question { font-family: var(--font-serif); font-size: clamp(20px, 3vw, 28px); color: var(--white); margin-bottom: 28px; line-height: 1.3; text-align: left; }
    .teaser-dimension { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; display: block; }

    /* Options */
    .teaser-options { display: flex; flex-direction: column; gap: 12px; }
    .teaser-option {
      display: flex; align-items: center; gap: 16px;
      padding: 16px 22px; border: 1.5px solid rgba(255,255,255,0.12);
      border-radius: var(--radius-md); background: transparent;
      color: rgba(255,255,255,0.85); font-size: 15px; cursor: pointer;
      transition: var(--transition); text-align: left; width: 100%;
      font-family: var(--font-sans);
    }
    .teaser-option:hover { border-color: var(--gold); background: rgba(184,151,90,0.08); transform: translateX(4px); }
    .teaser-option.selected { border-color: var(--gold); background: rgba(184,151,90,0.15); }
    .teaser-option-radio {
      width: 20px; height: 20px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.25); flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      transition: var(--transition);
    }
    .teaser-option.selected .teaser-option-radio { border-color: var(--gold); }
    .teaser-option.selected .teaser-option-radio::after { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--gold); }

    /* Nav */
    .teaser-nav { display: flex; justify-content: space-between; margin-top: 28px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.10); }
    .teaser-btn {
      padding: 12px 28px; border-radius: 100px; font-size: 14px; font-weight: 500;
      cursor: pointer; border: none; transition: var(--transition);
      font-family: var(--font-sans);
    }
    .teaser-btn-back { background: transparent; color: rgba(255,255,255,0.5); border: 1.5px solid rgba(255,255,255,0.15); }
    .teaser-btn-back:hover { color: var(--white); border-color: rgba(255,255,255,0.4); }
    .teaser-btn-next { background: linear-gradient(135deg, var(--gold-dark), var(--gold)); color: var(--white); }
    .teaser-btn-next:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(184,151,90,0.35); }
    .teaser-btn-next:disabled, .teaser-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }

    /* Results */
    .teaser-result { text-align: center; }
    .teaser-score-ring {
      width: 120px; height: 120px; margin: 0 auto 20px;
      border-radius: 50%; position: relative;
      background: conic-gradient(var(--gold) 0deg, rgba(255,255,255,0.10) 0deg);
      display: flex; align-items: center; justify-content: center;
    }
    .teaser-score-inner {
      width: 100px; height: 100px; border-radius: 50%;
      background: var(--charcoal); display: flex; align-items: center; justify-content: center;
      font-family: var(--font-serif); font-size: 36px; color: var(--gold);
    }
    .teaser-result-label { font-family: var(--font-serif); font-size: 22px; color: var(--white); margin-bottom: 10px; }
    .teaser-result-desc { font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.7; max-width: 460px; margin: 0 auto 28px; }

    .teaser-upsell {
      background: rgba(184,151,90,0.08);
      border: 1px solid rgba(184,151,90,0.20);
      border-radius: var(--radius-md);
      padding: 28px;
      margin: 24px 0;
      text-align: center;
    }
    .teaser-upsell-title { font-family: var(--font-serif); font-size: 18px; color: var(--white); margin-bottom: 10px; }
    .teaser-upsell-text { font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.6; margin-bottom: 20px; }
    .teaser-upsell-features { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; margin-bottom: 24px; }
    .teaser-upsell-feature { font-size: 13px; color: rgba(255,255,255,0.5); display: flex; align-items: center; gap: 6px; }
    .teaser-upsell-feature::before { content: '✦'; color: var(--gold); font-size: 10px; }

    .teaser-result-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

    /* Mini dimension bars in teaser results */
    .teaser-dimensions { max-width: 480px; margin: 24px auto 0; text-align: left; }
    .teaser-dim-title { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.6); margin-bottom: 16px; text-align: center; letter-spacing: 0.05em; text-transform: uppercase; }
    .teaser-dim-row { margin-bottom: 10px; }
    .teaser-dim-info { display: flex; justify-content: space-between; margin-bottom: 4px; }
    .teaser-dim-name { font-size: 13px; color: rgba(255,255,255,0.7); }
    .teaser-dim-score { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.5); }
    .teaser-dim-track { height: 6px; background: rgba(255,255,255,0.10); border-radius: 3px; overflow: hidden; }
    .teaser-dim-fill { height: 100%; background: linear-gradient(90deg, var(--gold-dark), var(--gold)); border-radius: 3px; transition: width 0.5s ease; }

    @media (max-width: 768px) {
      .teaser-hero-inner { padding: 48px 20px; }
      .teaser-wrap { padding: 32px 24px; }
      .teaser-nav { flex-direction: column; gap: 12px; }
      .teaser-nav .teaser-btn { width: 100%; }
      .teaser-result-cta { flex-direction: column; }
      .teaser-upsell-features { flex-direction: column; gap: 8px; }
    }
        .email-gate-icon {
      width: 64px; height: 64px; margin: 0 auto 24px;
      border-radius: 50%;
      background: rgba(184,151,90,0.12);
      border: 1px solid rgba(184,151,90,0.25);
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; color: var(--gold);
    }
    #teaserEmail::placeholder { color: rgba(255,255,255,0.3); }
    #teaserEmail:focus { border-color: var(--gold) !important; box-shadow: 0 0 0 3px rgba(184,151,90,0.12) !important; }
  </style>

<style id="unified-nav-styles">
  /* Full-width submenu bar: opens ACROSS THE TOP, under the nav */
  .nav-links .nav-group { position: static; align-self: stretch; display: flex; align-items: center; }
  .nav-links .nav-group > .nav-group-trigger { display: inline-flex; align-items: center; gap: 6px; height: 100%; position: relative; }
  .nav-links .nav-group > .nav-group-trigger::after { display: none; }
  .nav-caret { width: 9px; height: 9px; opacity: .65; transition: transform .3s cubic-bezier(.4,0,.2,1); }
  .nav-group:hover .nav-caret { transform: rotate(180deg); }
  .nav-dropdown {
    position: absolute; top: 100%; left: 0; right: 0; box-sizing: border-box;
    display: flex; flex-wrap: wrap; justify-content: center; align-items: stretch; gap: 6px;
    padding: 16px 32px;
    background: var(--white, #fff);
    border-top: 1px solid var(--border, rgba(0,0,0,.08));
    border-bottom: 1px solid var(--border, rgba(0,0,0,.08));
    box-shadow: 0 24px 50px rgba(28,28,30,.10);
    opacity: 0; visibility: hidden; pointer-events: none; transform: translateY(-8px);
    transition: opacity .24s ease, transform .24s cubic-bezier(.4,0,.2,1), visibility .24s; z-index: 9998;
  }
  .nav-dropdown::before { content: ''; position: absolute; left: 0; right: 0; top: -26px; height: 26px; }
  .nav-group:hover .nav-dropdown, .nav-group:focus-within .nav-dropdown {
    opacity: 1; visibility: visible; pointer-events: auto; transform: translateY(0);
  }
  .nav-dropdown a {
    display: block; padding: 12px 18px; border-radius: var(--radius-sm, 8px);
    font-size: 14px; line-height: 1.35; color: var(--text-primary, #1a1a1a);
    min-width: 180px; white-space: nowrap;
  }
  .nav-dropdown a::after { display: none; }
  .nav-dropdown a:hover { background: var(--cream, #f7f3ec); color: var(--gold-dark, #8b6e3a); }
  .nav-dropdown .dropdown-desc {
    display: block; margin-top: 3px; font-size: 12px; font-weight: 400;
    color: var(--text-secondary, #6b6b76); white-space: nowrap;
  }
  .nav-dropdown .tag {
    display: inline-block; margin-left: 8px; font-size: 10px; letter-spacing: .06em;
    text-transform: uppercase; color: var(--gold-dark, #8b6e3a);
    background: rgba(184,151,90,.14); padding: 2px 8px; border-radius: 100px; vertical-align: middle;
  }
  /* Featured "quick value" group */
  .nav-links .nav-group.featured > .nav-group-trigger { color: var(--gold-dark, #8b6e3a); font-weight: 600; }
  .nav-links .nav-group.featured > .nav-group-trigger .nav-caret { opacity: .9; }
  /* Active page state (set automatically by the injected script) */
  .nav-links > a.active { color: var(--text-primary, #1a1a1a); }
  .nav-links > a.active::after { transform: scaleX(1); }
  .nav-links > a.nav-cta.active { background: var(--gold, #b8975a); }
  .nav-links .nav-group.active > .nav-group-trigger { color: var(--gold-dark, #8b6e3a); font-weight: 600; }
  .nav-links .nav-group.active > .nav-group-trigger::before {
    content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 3px;
    background: var(--gold, #b8975a); border-radius: 3px 3px 0 0;
  }
  .nav-dropdown a.active { background: var(--cream, #f7f3ec); color: var(--gold-dark, #8b6e3a); font-weight: 600; }
  .mobile-menu a.active { color: var(--gold-dark, #8b6e3a); font-weight: 600; }
  /* Mobile grouped menu */
  .mobile-menu .m-label {
    display: block; padding: 20px 32px 2px; text-align: center;
    font-size: 11px; letter-spacing: .16em; text-transform: uppercase;
    color: var(--gold, #b8975a); border: none;
    font-family: var(--font-sans, system-ui, -apple-system, sans-serif);
  }
  .mobile-menu .m-label:first-child { padding-top: 10px; }
  .mobile-menu a.m-assess { color: var(--gold-dark, #8b6e3a); }
  .mobile-menu a.m-cta { color: var(--white, #fff); background: var(--charcoal, #1c1c1e); }
  @media (max-width: 1040px) { .nav-links { gap: 20px; } }
</style>
<script id="unified-nav-script">
document.addEventListener('DOMContentLoaded', function () {
  function seg(url) {
    try {
      var a = document.createElement('a'); a.href = url;
      var s = a.pathname.split('/').filter(Boolean).pop();
      return (s || 'index.html').toLowerCase();
    } catch (e) { return ''; }
  }
  var here = seg(window.location.href) || 'index.html';
  var links = document.querySelectorAll('#mainNav .nav-links a, #mobileMenu a');
  Array.prototype.forEach.call(links, function (link) {
    var href = link.getAttribute('href');
    if (!href || href.charAt(0) === '#' || href.indexOf('mailto:') === 0) return;
    if (seg(href) === here) {
      link.classList.add('active');
      var g = link.closest && link.closest('.nav-group');
      if (g) g.classList.add('active');
    }
  });
});
</script>
</head>
<body>

